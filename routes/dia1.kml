<kml xmlns="http://www.opengis.net/kml/2.2"><Document><name>Salamanca - Día 1</name><Style id="start"><IconStyle><color>ff335c67</color><Icon><href>http://maps.google.com/mapfiles/kml/paddle/wht-circle.png</href></Icon></IconStyle></Style><Style id="cafe"><IconStyle><color>ff3565c4</color><Icon><href>http://maps.google.com/mapfiles/kml/paddle/orange-circle.png</href></Icon></IconStyle></Style><Style id="monument"><IconStyle><color>ff317c46</color><Icon><href>http://maps.google.com/mapfiles/kml/paddle/grn-circle.png</href></Icon></IconStyle></Style><Style id="photo"><IconStyle><color>ff9c5a26</color><Icon><href>http://maps.google.com/mapfiles/kml/paddle/ylw-circle.png</href></Icon></IconStyle></Style><Style id="finish"><IconStyle><color>ff673ab7</color><Icon><href>http://maps.google.com/mapfiles/kml/paddle/purple-circle.png</href></Icon></IconStyle></Style><Style id="viewpoint"><IconStyle><color>ffb56a00</color><Icon><href>http://maps.google.com/mapfiles/kml/paddle/blu-circle.png</href></Icon></IconStyle></Style><Style id="route"><LineStyle><color>ff6a5634</color><width>5</width></LineStyle></Style><Placemark><name>01 · Zenit Hall88</name><description>17:00 - Salida puntual. Observa el cambio del barrio universitario al casco histórico.</description><styleUrl>#start</styleUrl><Point><coordinates>-5.6766756,40.9702112,0</coordinates></Point></Placemark><Placemark><name>02 · Café Novelty</name><description>17:24 - Pausa de 20-25 min en el café histórico fundado en 1905.</description><styleUrl>#cafe</styleUrl><Point><coordinates>-5.6636406,40.9653616,0</coordinates></Point></Placemark><Placemark><name>03 · Plaza Mayor</name><description>17:45 - Primera lectura del gran salón barroco de la ciudad.</description><styleUrl>#monument</styleUrl><Point><coordinates>-5.6640558,40.9650282,0</coordinates></Point></Placemark><Placemark><name>04 · Casa de las Conchas</name><description>17:57 - Fachada exterior y diálogo visual con la Clerecía.</description><styleUrl>#monument</styl